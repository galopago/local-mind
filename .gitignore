# Original source files may contain secrets — keep raw/ out of git
raw/*
!raw/.gitkeep

# Transient multi-file write markers (not wiki knowledge)
wiki/.link-operations/

# OS junk
.DS_Store
*.swp
*~

# Python
__pycache__/
*.pyc

# Autoresearch session files
autoresearch.jsonl
autoresearch.md
autoresearch.sh
autoresearch.checks.sh
autoresearch.ideas.md
autoresearch/

# Local demo output
link-demo/
.link-backups/
.link-cache/

# Local planning notes
planning/

# Integration artifacts (generated by install scripts)
CLAUDE.md
AGENTS.md
GEMINI.md
GEMINI.md
.cursor/
.kiro/
.github/copilot-instructions.md
.vscode/settings.json
.link-mcp-python

# PyPI build artifacts
mcp_package/dist/
mcp_package/*.egg-info/

# MCP registry auth tokens (personal credentials — never commit)
.mcpregistry_*
mcp_package/.mcpregistry_*

# Credential files
.env
.env.*
*.token
*.key
*.pem
*.p8
*.p12
id_rsa
id_ed25519
