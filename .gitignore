# Personal data — never commit
raw/*
!raw/.gitkeep

wiki/sources/*
!wiki/sources/.gitkeep

wiki/concepts/*
!wiki/concepts/.gitkeep

wiki/entities/*
!wiki/entities/.gitkeep

wiki/comparisons/*
!wiki/comparisons/.gitkeep

wiki/explorations/*
!wiki/explorations/.gitkeep

# Keep index and log templates but ignore personal content
# (we ship empty versions in the repo)
wiki/_link_schema.json

# OS junk
.DS_Store
*.swp
*~

# Python
__pycache__/
*.pyc

# Autoresearch session files
autoresearch.jsonl
autoresearch.md
autoresearch.sh
autoresearch.checks.sh
autoresearch.ideas.md
autoresearch/

# Local demo output
link-demo/
.link-backups/
.link-cache/

# Local planning notes
planning/

# Integration artifacts (generated by install scripts)
CLAUDE.md
AGENTS.md
GEMINI.md
GEMINI.md
.cursor/
.kiro/
.github/copilot-instructions.md
.vscode/settings.json
.link-mcp-python

# PyPI build artifacts
mcp_package/dist/
mcp_package/*.egg-info/

# MCP registry auth tokens (personal credentials — never commit)
.mcpregistry_*
mcp_package/.mcpregistry_*

# Credential files
.env
.env.*
*.token
*.key
*.pem
*.p8
*.p12
id_rsa
id_ed25519
