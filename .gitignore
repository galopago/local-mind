# Personal data — never commit
raw/*
!raw/.gitkeep

wiki/sources/*
!wiki/sources/.gitkeep

wiki/concepts/*
!wiki/concepts/.gitkeep

wiki/entities/*
!wiki/entities/.gitkeep

wiki/comparisons/*
!wiki/comparisons/.gitkeep

wiki/explorations/*
