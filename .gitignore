# Keep index and log templates but ignore personal content
# (we ship empty versions in the repo)

# OS junk
.DS_Store
*.swp
*~

# Python
__pycache__/
*.pyc

# Autoresearch session files
autoresearch.jsonl
autoresearch.md
autoresearch.sh
autoresearch.checks.sh
autoresearch.ideas.md
autoresearch/

